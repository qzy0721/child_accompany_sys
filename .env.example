# ============================================================
# API Keys (必填)
# ============================================================
DASHSCOPE_API_KEY=
LLM_API_KEY=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ============================================================
# 服务端口（留空时从 8000 起自动寻找可用端口）
# ============================================================
APP_PORT=

# ============================================================
# LLM 配置（可选，以下为默认值）
# ============================================================
LLM_API_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# ============================================================
# 语音引擎（cosyvoice 或 qwen_tts）
# ============================================================
DEFAULT_TTS_PROVIDER=cosyvoice

# ============================================================
# Qwen TTS 配置（可选）
# ============================================================
QWEN_TTS_TARGET_MODEL=qwen3-tts-vc-2026-01-22
QWEN_TTS_VOICE_PREFIX=vc
# 私有网关或其他地域可填写完整接口地址，通常留空即可。
QWEN_TTS_CUSTOMIZATION_URL=
QWEN_TTS_SYNTHESIS_URL=

# ============================================================
# CosyVoice 配置（可选）
# ============================================================
COSYVOICE_TARGET_MODEL=cosyvoice-v3.5-plus
COSYVOICE_SAMPLE_RATE=24000
COSYVOICE_VOICE_PREFIX=child_companion

# ============================================================
# OSS 配置（仅 CosyVoice 声音复刻需要）
# ============================================================
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=cosyvoice-reference-voice
OSS_REF_AUDIO_DIR=reference_audio

# ============================================================
# 实时 ASR（可选，默认沿用 Paraformer 实时模型）
# ============================================================
# 配置业务空间后使用推荐的专属 WebSocket 域名；不填会兼容旧域名。
DASHSCOPE_WORKSPACE_ID=
# 需要使用其他区域或私有网关时，可直接提供完整 wss 地址。
DASHSCOPE_ASR_WS_URL=
ASR_REALTIME_MODEL=paraformer-realtime-v2
ASR_VAD_SILENCE_MS=700

# ============================================================
# 对话参数（可选，以下为默认值）
# ============================================================
MAX_HISTORY=10
MAX_BUFFER_LENGTH=200
DEFAULT_ROLE_NAME=胡桃

# ============================================================
# 百度百科 Cookie（可选，爬虫用）
# ============================================================
BAIDU_COOKIE=
